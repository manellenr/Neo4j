MATCH (c:Container {name: "UPF MG1 POD"}), (s1:PhysicalServer {name: "Server12"}), (s2:PhysicalServer {name: "Server22"})
CREATE (c)-[:HOSTED_ON]->(s1), (c)-[:HOSTED_ON]->(s2);
MATCH (c:Container {name: "UPF MG2 POD"}), (s1:PhysicalServer {name: "Server13"}), (s2:PhysicalServer {name: "Server23"})
CREATE (c)-[:HOSTED_ON]->(s1), (c)-[:HOSTED_ON]->(s2);
MATCH (c:Container {name: "UPF LB2 POD"}), (s1:PhysicalServer {name: "Server16"}), (s2:PhysicalServer {name: "Server26"})
CREATE (c)-[:HOSTED_ON]->(s1), (c)-[:HOSTED_ON]->(s2);
MATCH (c:Container {name: "UPF MG3 POD"}), (s1:PhysicalServer {name: "Server17"}), (s2:PhysicalServer {name: "Server28"})
CREATE (c)-[:HOSTED_ON]->(s1), (c)-[:HOSTED_ON]->(s2);

MATCH (m:Microservices {name: "UPF OAM1"}), (s1:PhysicalServer {name: "Server14"}), (s2:PhysicalServer {name: "Server24"})
CREATE (m)-[:DEPLOYED_ON]->(s1), (m)-[:DEPLOYED_ON]->(s2);
MATCH (m:Microservices {name: "UPF OAM2"}), (s1:PhysicalServer {name: "Server15"}), (s2:PhysicalServer {name: "Server25"})
